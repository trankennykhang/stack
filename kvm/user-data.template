#cloud-config
hostname: __HOSTNAME__
package_update: true
package_upgrade: true
# This ensures the machine-id is unique on boot
system_info:
  default_user:
    name: kenny
# 1. Add keys to the default 'ubuntu' user or a specific user
users:
  - name: kenny
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    lock_passwd: false
    # Paste your PUBLIC key (.pub) here
    ssh_authorized_keys:
      - ssh-rsa  kenny@kenny-HP-Z600-Workstation

# 2. Alternatively, add keys to the system-wide default user
# Ensure the SSH service is enabled and configured
ssh_pwauth: false # Good practice: disable password login for security 
